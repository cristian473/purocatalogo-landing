---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Página no encontrada - PuroCatálogo"
  description="La página que buscás no existe o fue movida. Volvé al inicio de PuroCatálogo."
>
  <Header />
  <main id="main-content">
    <section class="py-20 md:py-32">
      <div class="container-custom text-center">
        <h1 class="text-9xl font-bold text-primary-600 mb-8">404</h1>
        <h2 class="text-3xl md:text-4xl font-bold text-text-main mb-4">Página no encontrada</h2>
        <p class="text-xl text-text-muted mb-8 max-w-2xl mx-auto">
          La página que buscás pudo haber sido eliminada, cambiada de nombre o no está disponible temporalmente.
        </p>
        <div class="flex justify-center gap-4 flex-wrap">
          <a href="/" class="btn-primary">
            Volver al inicio
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
