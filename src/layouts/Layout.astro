---
import '../styles/global.css';
import '../styles/transitions.css';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "PuroCatálogo - Catálogos Digitales Profesionales",
  description = "Transforma tu lista de productos en un catálogo digital elegante que convierte visitantes en clientes. Sin código, sin complicaciones.",
  jsonLd,
} = Astro.props;

const ogImage = "/purocatalogo-og-image.png";
const siteUrl = "https://purocatalogo.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#026aeb" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="PuroCatálogo" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    <!-- TODO: Descomentar y actualizar con la cuenta real de X/Twitter -->
    <!-- <meta name="twitter:site" content="@purocatalogo" /> -->
    <!-- <meta name="twitter:creator" content="@purocatalogo" /> -->

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload critical fonts -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Instrument+Sans:wght@400;500;600;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Material Symbols loaded async to avoid render-blocking -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@400,0..1&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@400,0..1&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@400,0..1&display=swap" rel="stylesheet" /></noscript>
    
    <!-- Structured Data -->
    {jsonLd && (
      Array.isArray(jsonLd) 
        ? jsonLd.map((schema) => (
            <script type="application/ld+json" set:html={JSON.stringify(schema)} />
          ))
        : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <ClientRouter />
  </head>
  <body class="antialiased bg-white text-secondary-900">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary-500 focus:text-white focus:px-4 focus:py-2 focus:rounded focus:text-sm focus:font-bold">
      Saltar al contenido principal
    </a>
    <div id="page-wrapper" class="page-transition-wrapper page-loaded">
      <slot />
    </div>
    <script>
      // Handle page transitions
      document.addEventListener('astro:page-load', () => {
        const pageWrapper = document.getElementById('page-wrapper');
        if (pageWrapper) {
          pageWrapper.classList.add('page-loaded');
        }
      });

      document.addEventListener('astro:before-swap', () => {
        const pageWrapper = document.getElementById('page-wrapper');
        if (pageWrapper) {
          pageWrapper.classList.remove('page-loaded');
        }
      });
    </script>
    <script src="../scripts/transitions.js"></script>

    <!-- Google tag (gtag.js) - GA4 + Google Ads -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1CCSV49JQF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1CCSV49JQF');
      gtag('config', 'AW-18014070783');

      window.trackEvent = function(eventName, eventParams) {
        gtag('event', eventName, eventParams || {});
      };

      window.trackConversion = function(url) {
        gtag('event', 'conversion', {
          'send_to': 'AW-18014070783',
          'event_callback': function() {
            if (url) { window.open(url, '_blank') || (window.location.href = url); }
          }
        });
        // Fallback si el callback no ejecuta en 1s
        if (url) {
          setTimeout(function() {
            window.open(url, '_blank') || (window.location.href = url);
          }, 1000);
        }
      };
    </script>
  </body>
</html>
