---
const features = [
  {
    title: "Venta Directa por WhatsApp",
    description: "Tu cliente arma el pedido solo. A vos te llega listo para despachar.",
    icon: "chat",
    color: "green",
    dark: false
  },
  {
    title: "Cero Comisiones",
    description: "Vendé $100 o $10 millones: pagás lo mismo todos los meses.",
    icon: "payments",
    color: "primary",
    dark: true
  },
  {
    title: "Fidelización y Login",
    description: "Tus clientes mayoristas ven sus precios y su historial. Sin que les mandes nada.",
    icon: "person_check",
    color: "purple",
    dark: false
  },
  {
    title: "Gestión Multi-Usuario",
    description: "Tu equipo actualiza productos y stock desde su cuenta. Vos controlás todo.",
    icon: "groups",
    color: "orange",
    dark: false
  },
  {
    title: "Integraciones a Medida",
    description: "Conectamos PuroCatálogo con tu sistema actual. ERP, facturación, lo que necesites.",
    icon: "api",
    color: "primary",
    dark: false
  },
  {
    title: "Estabilidad Garantizada",
    description: "Tu catálogo va a estar online siempre. Aunque te compartan el link 10.000 veces.",
    icon: "shield",
    color: "pink",
    dark: false
  }
];

const colorClasses: Record<string, string> = {
  green: "text-green-500",
  primary: "text-primary-500",
  purple: "text-purple-500",
  orange: "text-orange-500",
  pink: "text-pink-500"
};
---

<section id="features" class="py-20 bg-background-subtle">
  <div class="px-8 md:px-16 lg:px-24 max-w-[1440px] mx-auto">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-baseline mb-12 gap-6">
      <div class="max-w-xl space-y-4">
        <h2 class="text-4xl font-extrabold text-text-main">Funciones que trabajan por vos.</h2>
        <p class="text-text-muted text-base font-medium">Desde el primer producto hasta el catálogo número 100.</p>
      </div>
      <a class="text-primary-500 font-bold text-xs uppercase tracking-widest flex items-center gap-2 hover:gap-3 transition-all" href="#pricing">
        Ver todas las funciones <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span>
      </a>
    </div>
    
    <!-- Feature Cards: Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class={`p-6 md:p-8 rounded-3xl border transition-colors duration-300 flex flex-col h-full ${
          feature.dark 
            ? 'bg-primary-50 border-primary-100 shadow-lg shadow-primary-500/5' 
            : 'bg-white border-secondary-100 shadow-lg shadow-secondary-200/50'
        }`}>
          <div class={`w-12 h-12 rounded-2xl flex items-center justify-center mb-6 ${
            feature.dark ? 'bg-primary-100' : 'bg-primary-50'
          }`}>
            <span class={`material-symbols-outlined text-2xl ${feature.dark ? 'text-primary-500' : colorClasses[feature.color]}`} aria-hidden="true">
              {feature.icon}
            </span>
          </div>
          <h3 class={`text-xl font-extrabold mb-3 ${feature.dark ? 'text-text-main' : 'text-text-main'}`}>
            {feature.title}
          </h3>
          <p class={`text-sm leading-relaxed font-medium flex-1 ${feature.dark ? 'text-secondary-600' : 'text-secondary-500'}`}>
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
