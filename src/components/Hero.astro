---
---
<section class="pt-14 lg:min-h-screen flex flex-col lg:flex-row border-b border-secondary-100">
  <!-- Left Column: Text Content -->
    <div class="w-full lg:w-1/2 flex flex-col justify-center px-8 md:px-16 lg:px-24 py-20 bg-white">
    <div class="max-w-xl space-y-8">
      <!-- Title -->
      <h1 class="text-4xl md:text-6xl xl:text-7xl font-extrabold leading-[1.05] text-text-main">
        Tu catálogo online en minutos. <br/>
        <span class="text-primary-500">Simple para arrancar, potente para escalar.</span>
      </h1>

      <!-- Description -->
      <p class="text-lg text-text-muted font-normal leading-relaxed max-w-2xl">
        Cargá tus productos, compartilos por WhatsApp y empezá a recibir pedidos hoy. Sin código, sin comisiones, sin depender de nadie.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col gap-4 pt-4">
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="https://admin.purocatalogo.com/register"
            class="h-12 px-8 bg-primary-500 text-white text-xs font-bold hover:bg-primary-dark transition-all rounded-full flex items-center justify-center gap-2"
            onclick="window.trackEvent && window.trackEvent('cta_click', {cta_location: 'hero', cta_text: 'Creá tu catálogo gratis'})"
          >
            Creá tu catálogo gratis
          </a>

        </div>
        <p class="text-[11px] text-text-muted font-medium flex items-center gap-4">
          <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm text-primary-500" aria-hidden="true">check_circle</span> Sin tarjeta de crédito</span>
          <span class="flex items-center gap-1"><span class="material-symbols-outlined text-sm text-primary-500" aria-hidden="true">bolt</span> Listo en 2 minutos</span>
        </p>
      </div>

      <!-- Trust Indicators -->
      <div class="pt-12 border-t border-secondary-100 mt-12">
        <p class="text-[10px] font-bold text-secondary-400 uppercase tracking-widest mb-6">Industrias que usan PuroCatálogo</p>
        <div class="flex flex-wrap gap-8 items-center grayscale opacity-40">
          <div class="flex items-center gap-2 font-bold text-sm text-text-main">
            <span class="material-symbols-outlined text-base" aria-hidden="true">checkroom</span> Fashion
          </div>
          <div class="flex items-center gap-2 font-bold text-sm text-text-main">
            <span class="material-symbols-outlined text-base" aria-hidden="true">chair</span> Decor
          </div>
          <div class="flex items-center gap-2 font-bold text-sm text-text-main">
            <span class="material-symbols-outlined text-base" aria-hidden="true">restaurant</span> Food
          </div>
          <div class="flex items-center gap-2 font-bold text-sm text-text-main">
            <span class="material-symbols-outlined text-base" aria-hidden="true">diamond</span> Joyas
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right Column: Phone Mockup -->
  <div class="hidden lg:flex w-full lg:w-1/2 bg-background-subtle items-center justify-center p-8 lg:p-12 relative overflow-hidden border-l border-secondary-100">
    <!-- Dotted Background Pattern -->
    <div class="absolute top-0 right-0 w-full h-full bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] [background-size:32px_32px] opacity-50"></div>

    <!-- Phone Mockup -->
    <div class="relative w-full max-w-[320px] lg:max-w-[380px] aspect-[9/18] bg-secondary-900 rounded-[2.5rem] p-3 shadow-2xl z-10 border border-secondary-800">
      <div class="w-full h-full bg-white rounded-[2rem] overflow-hidden flex flex-col relative">
        <!-- Phone Header -->
        <div class="bg-white p-4 border-b border-secondary-100 flex justify-between items-center">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 bg-primary-500 rounded-full flex items-center justify-center text-white font-bold text-[10px]">PC</div>
            <span class="text-[10px] font-bold uppercase tracking-wider text-text-main">Mi Tienda</span>
          </div>
          <span class="material-symbols-outlined text-secondary-400 text-lg" aria-hidden="true">menu</span>
        </div>

        <!-- Phone Content -->
        <div class="flex-1 overflow-y-auto no-scrollbar bg-white p-4 space-y-4">
          <!-- Hero Banner -->
          <div class="h-40 rounded-lg overflow-hidden relative">
            <img
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDgTW8eHeaebv4UEHip6yxGfkk6NyJQeyTi2NZyC4EQT9brrrz33o2pycz7zo0TG1lUvSo_ns9IpPvCrOind2JcF_4Io7ArU6j1i2y35HIOHdlWnstHJkNVDPawECMIXHdV-3G5YTLik4oaRDp23YDZui9CO2WOE85lcC4vy_gX2id1-jrl66prHn1dKEXd-eGuYBHx0FYOaybCdzfDQGGkB6kq1ADae3p_l3-TBm1R0-rLk5ec_UbeB0p78a5T81j3dSiU_IYoEzR0"
              alt="Banner de colección de moda 2024 mostrando productos destacados"
              class="w-full h-full object-cover"
              loading="lazy"
              width="380"
              height="160"
            />
            <div class="absolute inset-0 bg-black/20 flex items-end p-4">
              <span class="text-white text-[10px] font-extrabold uppercase tracking-widest">Colección 2024</span>
            </div>
          </div>

          <!-- Product Grid -->
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-secondary-50 p-2 rounded">
              <div class="aspect-square mb-2 rounded overflow-hidden">
                <img
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuA3bhJiBelpGM1EL5sHsoPLRRLZQ9t5R4hD0zWAdIS5flB21H8JqBkp9lVlcb9P86gMXaZOCXpcmpcbsrbEeqyyMPusjWhiMdxbIXvsWUptqvcxmTagFp3CNPFJLiZi0C0mNfv5_1J9yTM7zQdQj1xFhh8XcOajZKs6_gWheUR-EnDRKz9zzorD85SIcsyOOAjY8FabW9ghYdkNz4wP5wlxAVNUt-elIFlpzaWpbG-UYAg8Mh1qp8VX-1VMKMS1XiBexW18FdgN5rXB"
                  alt="Producto de moda: prenda destacada del catálogo"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width="160"
                  height="160"
                />
              </div>
              <div class="h-2 w-3/4 bg-secondary-200 mb-1 rounded"></div>
              <div class="h-2 w-1/2 bg-primary-100 rounded"></div>
            </div>
            <div class="bg-secondary-50 p-2 rounded">
              <div class="aspect-square mb-2 rounded overflow-hidden">
                <img
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuC5PR_XuZTGnjlFG02rKxcMsUiNy1LVfGTSAmmiopeCZM7alyaLmY1kgUtULwpHIb6t1v-QcrSl5OKpqm0rZ0JBmNsHtWul_uAWEte7nJZqeFIdyOCG0wwsL_IugZOU0OUfBPzOt0Pb0dcspPZYexc3Qp-31h7tMnM_KHqZaClp-MjPniWY86DHNsRuETefqS6UHZYddkVttxLIBvXxpy1EorIIoU-UIdzK6WByH_K2vbm_ZjEvjKgNmrZx4uUF8mrDen9oTM6DL0hj"
                  alt="Producto de moda: accesorio del catálogo"
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width="160"
                  height="160"
                />
              </div>
              <div class="h-2 w-3/4 bg-secondary-200 mb-1 rounded"></div>
              <div class="h-2 w-1/2 bg-primary-100 rounded"></div>
            </div>
          </div>
        </div>

        <!-- Phone Footer: WhatsApp Button -->
        <div class="p-4 bg-white border-t border-secondary-50">
          <div class="w-full h-10 bg-[#25D366] text-white flex items-center justify-center gap-2 text-[10px] font-bold uppercase tracking-widest rounded" aria-hidden="true">
            <span class="material-symbols-outlined text-sm">chat</span> WhatsApp
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
