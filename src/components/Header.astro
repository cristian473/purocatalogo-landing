---
---
<header class="fixed top-0 z-50 w-full border-b border-secondary-100 bg-white h-14 lg:h-16">
  <div class="h-full px-6 lg:px-8 flex items-center justify-between max-w-[1440px] mx-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center" aria-label="PuroCatálogo - Volver al inicio">
      <img src="/images/logo.png" alt="PuroCatálogo" class="h-7 lg:h-8 w-auto" />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8 lg:gap-10" aria-label="Navegación principal">
      <a href="#features" class="text-xs lg:text-sm font-semibold text-text-muted hover:text-primary-500 transition-colors">Funciones</a>
      <a href="#pricing" class="text-xs lg:text-sm font-semibold text-text-muted hover:text-primary-500 transition-colors">Precios</a>
      <a href="#examples" class="text-xs lg:text-sm font-semibold text-text-muted hover:text-primary-500 transition-colors">Ejemplos</a>
    </nav>

    <!-- Right Side Actions -->
    <div class="flex items-center gap-5 lg:gap-6">
      <!-- Login link -->
      <a href="https://admin.purocatalogo.com" class="hidden lg:block text-sm font-bold text-text-main hover:text-primary-500 transition-colors">Iniciar sesión</a>

      <!-- CTA Button -->
      <a
        href="https://admin.purocatalogo.com/register"
        class="hidden sm:inline-flex h-9 lg:h-10 px-5 lg:px-6 bg-primary-500 text-white text-xs lg:text-sm font-bold items-center justify-center hover:bg-primary-dark transition-all rounded-full"
        onclick="window.trackEvent && window.trackEvent('cta_click', {cta_location: 'header', cta_text: 'Empezar gratis'})"
      >
        Empezar gratis
      </a>

      <!-- Mobile Menu Button -->
      <div x-data="{ open: false }" class="md:hidden">
        <button
          @click="open = !open"
          class="w-10 h-10 flex items-center justify-center text-text-main rounded-lg"
          :aria-expanded="open"
          aria-label="Abrir menú de navegación"
        >
          <span x-show="!open" class="material-symbols-outlined text-lg" aria-hidden="true">menu</span>
          <span x-show="open" class="material-symbols-outlined text-lg" x-cloak aria-hidden="true">close</span>
        </button>

        <!-- Mobile Menu Dropdown -->
        <nav
          x-show="open"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-2"
          class="absolute top-14 left-0 right-0 bg-white border-b border-secondary-100 shadow-lg"
          x-cloak
          aria-label="Navegación móvil"
        >
          <div class="px-6 py-4 space-y-4">
            <a href="#features" @click="open = false" class="block text-sm font-semibold text-text-main hover:text-primary-500">Funciones</a>
            <a href="#pricing" @click="open = false" class="block text-sm font-semibold text-text-main hover:text-primary-500">Precios</a>
            <a href="#examples" @click="open = false" class="block text-sm font-semibold text-text-main hover:text-primary-500">Ejemplos</a>
            <div class="pt-4 border-t border-secondary-100">
              <a href="https://admin.purocatalogo.com" class="block text-sm font-bold text-text-muted mb-4">Iniciar sesión</a>
              <a
                href="https://admin.purocatalogo.com/register"
                class="block w-full h-10 bg-primary-500 text-white text-xs font-bold flex items-center justify-center rounded-full hover:bg-primary-dark transition-all"
                onclick="window.trackEvent && window.trackEvent('cta_click', {cta_location: 'mobile_menu', cta_text: 'Empezar gratis'})"
              >
                Empezar gratis
              </a>
            </div>
          </div>
        </nav>
      </div>
    </div>
  </div>
</header>
