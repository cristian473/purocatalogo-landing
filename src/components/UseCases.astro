---
const useCases = [
  {
    title: "Emprendedores y Showrooms",
    problem: "Mandás fotos sueltas por WhatsApp y perdés el control de precios y stock.",
    solution: "Un link profesional para tu bio. Armás el catálogo desde el celular en minutos y empezás a vender gratis.",
    tag: "Agilidad",
    image: "https://images.unsplash.com/photo-1556740738-b6a63e27c4df?auto=format&fit=crop&q=80&w=800",
    imageAlt: "Emprendedora organizando productos en su showroom",
    link: null,
    linkText: null
  },
  {
    title: "PyMEs y Mayoristas",
    problem: "500 productos, vendedores mandando PDFs y listas desactualizadas.",
    solution: "Login de clientes, listas de precios diferenciadas y panel para todo tu equipo. Control total sin complejidad.",
    tag: "Robustez",
    image: "https://images.unsplash.com/photo-1553413077-190dd305871c?auto=format&fit=crop&q=80&w=800",
    imageAlt: "Almacén mayorista con productos organizados en estantes",
    link: null,
    linkText: null
  },
  {
    title: "Grandes Empresas",
    problem: "Necesitás integración con tu sistema y que el catálogo no se caiga nunca.",
    solution: "API propia, marca blanca y un equipo que se encarga de que todo funcione. Soporte dedicado incluido.",
    tag: "Corporativo",
    image: "https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=800",
    imageAlt: "Oficina corporativa moderna con equipo de trabajo",
    link: null,
    linkText: null
  }
];
---

<section id="examples" class="py-20 bg-white">
  <div class="px-8 md:px-16 lg:px-24 max-w-[1440px] mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-baseline mb-12 gap-6">
      <div class="max-w-xl space-y-4">
        <p class="text-[10px] font-bold text-primary-500 uppercase tracking-[0.2em]">Para cada etapa</p>
        <h2 class="text-4xl font-extrabold text-text-main">No importa el tamaño: PuroCatálogo se adapta.</h2>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      {useCases.map((useCase) => (
        <div class="group relative bg-white rounded-3xl overflow-hidden border border-secondary-100 flex flex-col h-full shadow-lg shadow-secondary-200/50 hover:shadow-xl hover:border-secondary-200 transition-all duration-500">
          <!-- Image Header -->
          <div class="relative h-48 overflow-hidden">
            <img
              src={useCase.image}
              alt={useCase.imageAlt}
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
              width="800"
              height="400"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-white to-transparent opacity-80"></div>
            <div class="absolute top-4 left-4 bg-white/90 px-3 py-1 rounded-full text-xs font-black uppercase tracking-widest text-primary-500 border border-secondary-100 shadow-sm">
              {useCase.tag}
            </div>
          </div>

          <!-- Content -->
          <div class="p-6 md:p-8 flex-1 flex flex-col relative">
            <h3 class="text-2xl font-extrabold text-text-main mb-4">
              {useCase.title}
            </h3>

            <p class="text-text-muted text-sm leading-relaxed mb-6 flex items-start gap-2">
              <span class="material-symbols-outlined text-red-400 text-base mt-0.5 flex-shrink-0" aria-hidden="true">warning</span>
              {useCase.problem}
            </p>

            <div class="mt-auto pt-6 border-t border-secondary-100">
              <p class="text-sm font-bold text-primary-600 leading-relaxed flex items-start gap-2">
                <span class="material-symbols-outlined text-lg flex-shrink-0" aria-hidden="true">check_circle</span>
                {useCase.solution}
              </p>
              {useCase.link && (
                <a
                  href={useCase.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 mt-4 text-xs font-bold text-primary-500 uppercase tracking-widest hover:gap-2.5 transition-all"
                >
                  {useCase.linkText} <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
