---
const plans = [
  {
    name: "Inicial",
    priceArs: "0",
    priceUsd: "0",
    level: "Nivel 01",
    description: "Perfecto para probar la plataforma sin riesgos.",
    features: [
      "1 Catálogo",
      "Hasta 15 productos",
      "1 Foto por producto",
      "Enlace personalizado (tumarca.purocatalogo.com)",
      "Marca de agua de PuroCatálogo en pie de página",
      "Soporte básico por email",
      "Sin comisiones por venta"
    ],
    cta: "Empezar gratis",
    popular: false,
    highlighted: false
  },
  {
    name: "Negocio Pro",
    priceArs: "29.900",
    priceUsd: "24",
    level: "Nivel 02",
    description: "Para negocios que necesitan automatizar y fidelizar.",
    features: [
      "Todo lo incluido en Inicial",
      "Hasta 2 catálogos",
      "Hasta 100 productos",
      "Máximo 5 Fotos por producto",
      "Enlace personalizado (tumarca.com)",
      "Múltiples usuarios para gestionar el catálogo",
      "Módulos y funcionalidades extras (newsletter, analíticas, etc.)"
    ],
    cta: "Elegir Negocio Pro",
    popular: true,
    highlighted: true
  },
  {
    name: "Empresa",
    priceArs: "79.900",
    priceUsd: "59",
    level: "Nivel 03",
    description: "Nosotros nos encargamos de todo. Vos vendés.",
    features: [
      "Todo lo incluido en Negocio Pro",
      "Sin límites",
      "Enlace personalizado (tumarca.com)",
      "Configuración inicial del sitio (Banner, Logo, etc.)",
      "Gestor del sitio dedicado",
      "Login y registro de clientes en el catálogo",
      "Generar APP móvil y módulo para enviar notificaciones (opcional)",
      "Soporte prioritario por WhatsApp"
    ],
    cta: "Contactar un asesor",
    popular: false,
    highlighted: false
  }
];
---

<section id="pricing" class="py-20 bg-background-subtle border-y border-secondary-100"
  x-data={`{
    currency: (() => {
      try {
        const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
        return (tz.includes('Argentina') || tz.includes('Buenos_Aires')) ? 'ARS' : 'USD';
      } catch(e) { return 'ARS'; }
    })()
  }`}
>
  <div class="px-8 md:px-16 lg:px-24 max-w-[1440px] mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12 max-w-2xl mx-auto">
      <h2 class="text-4xl font-extrabold text-text-main mb-4">Elegí tu plan. Sin comisiones, sin letra chica.</h2>
      <p class="text-text-muted text-base font-medium">Empezá gratis y escalá cuando quieras. Cambiás de plan en cualquier momento.</p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto items-stretch">
      {plans.map((plan) => (
        <div class={`p-8 rounded-3xl flex flex-col justify-between transition-all duration-300 ${
          plan.highlighted
            ? 'bg-primary-50 border-2 border-primary-300 shadow-xl shadow-primary-500/10 lg:scale-[1.03] relative'
            : 'bg-white border border-secondary-100 shadow-lg shadow-secondary-200/50'
        }`}>
          <div>
            <!-- Level & Popular Badge -->
            <div class="flex justify-between items-center mb-4">
              <span class={`text-xs font-black uppercase tracking-widest ${
                plan.highlighted ? 'text-primary-600' : 'text-secondary-400'
              }`}>{plan.level}</span>
              {plan.popular && (
                <span class="text-[10px] font-black uppercase bg-primary-500 text-white px-3 py-1 rounded-full">Popular</span>
              )}
            </div>

            <!-- Plan Name -->
            <h3 class="text-2xl font-extrabold mb-2 text-text-main">{plan.name}</h3>

            <!-- Price: auto-detected by region -->
            <div class="flex items-baseline gap-1 mb-6">
              <span class={`text-4xl font-black ${plan.highlighted ? 'text-primary-600' : 'text-text-main'}`}>
                <template x-if="currency === 'ARS'">
                  <span>${plan.priceArs}</span>
                </template>
                <template x-if="currency === 'USD'">
                  <span>US${plan.priceUsd}</span>
                </template>
              </span>
              <span class="text-sm font-bold text-secondary-400">
                {plan.priceArs !== "0" ? `/ mes` : " para siempre"}
              </span>
            </div>

            <!-- Description -->
            <p class={`text-sm mb-8 leading-relaxed font-medium ${plan.highlighted ? 'text-secondary-600' : 'text-secondary-500'}`}>
              {plan.description}
            </p>

            <!-- Features -->
            <ul class="space-y-3 mb-8">
              {plan.features.map(feature => (
                <li class={`flex gap-3 text-sm font-medium ${plan.highlighted ? 'text-secondary-700' : 'text-secondary-600'}`}>
                  <span class="flex-shrink-0 material-symbols-outlined text-[18px] text-primary-500" aria-hidden="true">check</span> {feature}
                </li>
              ))}
            </ul>
          </div>

          <!-- CTA Button -->
          <a
            href={plan.name === "Empresa" ? "https://wa.me/5491164039597?text=Hola%2C%20me%20interesa%20el%20plan%20Empresa%20de%20PuroCat%C3%A1logo.%20%C2%BFPodr%C3%ADan%20darme%20m%C3%A1s%20info%3F" : "https://admin.purocatalogo.com/register"}
            class={`w-full py-4 rounded-full font-bold text-xs uppercase tracking-widest text-center transition-all ${
              plan.highlighted
                ? 'btn-primary justify-center'
                : 'btn-outline justify-center border-2'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Corporate Contact -->
    <div class="mt-20 text-center p-6 md:p-12 bg-white border border-secondary-100 rounded-3xl max-w-4xl mx-auto shadow-sm">
      <h3 class="text-2xl font-extrabold text-text-main mb-4">¿Tu operación necesita algo a medida?</h3>
      <p class="text-text-muted mb-8 text-sm">Integraciones, API propia, marca blanca y un equipo dedicado a tu proyecto.</p>
      <a
        href="https://wa.me/5491164039597?text=Hola%2C%20necesito%20una%20soluci%C3%B3n%20a%20medida%20para%20mi%20negocio.%20%C2%BFPodemos%20coordinar%20una%20llamada%3F"
        class="btn-secondary h-12 px-8"
      >
        <span class="material-symbols-outlined text-sm" aria-hidden="true">support_agent</span> Hablemos con un asesor
      </a>
    </div>
  </div>
</section>
