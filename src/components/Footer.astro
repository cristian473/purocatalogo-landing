---
const currentYear = new Date().getFullYear();
---

<footer class="bg-text-main text-white pt-20 pb-12">
  <div class="px-8 md:px-16 lg:px-24 max-w-[1440px] mx-auto">
    <!-- Top Section: CTA and Links -->
    <div class="grid lg:grid-cols-2 gap-20 pb-20 border-b border-white/10">
      <!-- Left: CTA -->
      <div class="max-w-md">
        <h2 class="text-4xl md:text-5xl font-extrabold mb-6 leading-none text-white">¿Cuántas ventas perdiste hoy por no tener un catálogo?</h2>
        <p class="text-secondary-400 text-lg mb-8 font-medium">Empezá gratis, sin tarjeta. Tu catálogo online en menos de 2 minutos.</p>
        <a
          href="https://admin.purocatalogo.com/register"
          class="btn-primary h-12 px-8"
          onclick="window.trackEvent && window.trackEvent('cta_click', {cta_location: 'footer', cta_text: 'Creá tu catálogo gratis'})"
        >
          Creá tu catálogo gratis
        </a>
      </div>

      <!-- Right: Links -->
      <nav class="grid grid-cols-2 gap-8 md:gap-12 text-sm" aria-label="Enlaces del pie de página">
        <div class="flex flex-col gap-6">
          <span class="text-[10px] font-black uppercase tracking-widest text-primary-500">Producto</span>
          <div class="flex flex-col gap-4 font-bold text-secondary-400">
            <a class="hover:text-white transition-colors flex items-center gap-2 group" href="/#features">
              Funciones <span class="material-symbols-outlined text-[10px] opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" aria-hidden="true">arrow_forward</span>
            </a>
            <a class="hover:text-white transition-colors flex items-center gap-2 group" href="/#pricing">
              Precios <span class="material-symbols-outlined text-[10px] opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" aria-hidden="true">arrow_forward</span>
            </a>
            <a class="hover:text-white transition-colors flex items-center gap-2 group" href="/#examples">
              Ejemplos <span class="material-symbols-outlined text-[10px] opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
        </div>
        <div class="flex flex-col gap-6">
          <span class="text-[10px] font-black uppercase tracking-widest text-primary-500">Legal</span>
          <div class="flex flex-col gap-4 font-bold text-secondary-400">
            <a class="hover:text-white transition-colors" href="/privacy-policy">Privacidad</a>
            <a class="hover:text-white transition-colors" href="/terms-conditions">Términos</a>
          </div>
        </div>
      </nav>
    </div>

    <!-- Copyright & Attribution -->
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-between gap-6 text-secondary-500">
      <p class="text-[11px] tracking-wide uppercase font-medium">
        © {currentYear} PuroCatálogo — Todos los derechos reservados
      </p>
      <a
        href="https://puro.software"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-1.5 text-[11px] tracking-wide uppercase font-medium text-secondary-500 hover:text-primary-400 transition-colors duration-300"
        aria-label="Visitar puro.software, creadores de PuroCatálogo"
      >
        <span>Hecho por</span>
        <span class="font-extrabold text-secondary-300 group-hover:text-primary-400 transition-colors duration-300">puro.software</span>
        <span class="material-symbols-outlined text-[10px] opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" aria-hidden="true">north_east</span>
      </a>
    </div>
  </div>
</footer>
